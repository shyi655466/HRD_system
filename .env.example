# 复制为仓库根目录 .env 后填写。settings 会由 python-dotenv 加载本文件；已存在的环境变量优先生效。
# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL
MYSQL_DATABASE=hrd_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=33061
# 置空或注释表示使用 TCP 连接；可改为 Unix socket 路径
MYSQL_UNIX_SOCKET=

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# 生信（可选，缺省为仓库下 pipeline/ 与 pipeline/work/）
# HRD_PIPELINE_ROOT=
# HRD_PIPELINE_WORK_ROOT=
# HRD_WGS_REF_FA=
# HRD_WGS_THREADS=8
# HRD_RSCRIPT=
# WES 参考与线程（未设置时 WES 参考默认同 WGS，线程默认同 WGS）
# HRD_WES_REF_FA=
# HRD_WES_THREADS=
# HRD_WES_SCAR_REFERENCE=
# 子进程超时（秒），不设或 <=0 表示不限制
# HRD_WES_SUBPROCESS_TIMEOUT=
# HRD_WGS_SUBPROCESS_TIMEOUT=
