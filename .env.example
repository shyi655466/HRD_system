# 复制为仓库根目录下的 .env 后填写。backend 会在加载 settings 时自动读取该文件（python-dotenv）；
# 已在环境中的变量优先生效，不会被 .env 覆盖。
#
# Django（生产环境务必设置 DJANGO_SECRET_KEY，并设 DJANGO_DEBUG=false）
# docker compose 起 web 时，API 映射为 http://127.0.0.1:8010/（与 frontend/vite 代理一致）
# 按需加 Nginx 静态入口: docker compose --profile frontend up -d → http://127.0.0.1:8080/
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL
# 宿主机运行 Django / 本地 Celery 时：连 docker compose 映射端口（与 docker-compose.yml 中 db 服务一致）
# 容器内 worker 使用 MYSQL_HOST=db、MYSQL_PORT=3306，勿照抄到本机 .env
MYSQL_DATABASE=hrd_db
MYSQL_USER=hrd_app
MYSQL_PASSWORD=hrd_app_change_me
MYSQL_HOST=127.0.0.1
MYSQL_PORT=33061
# 置空表示仅 TCP，不配置 unix_socket（与 compose worker 中 MYSQL_UNIX_SOCKET="" 语义一致）
MYSQL_UNIX_SOCKET=

# Celery / Redis
# 宿主机 Worker 连 compose 暴露的 Redis；与 worker 服务内 redis://redis:6379 指向同一实例
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
